# ============================================================
# Required variables
# ============================================================
TOKEN={ TOKEN_BOT_TELEGRAM }
ADMIN_ID={ TELEGRAM_ADMIN_USER_ID_NUMBER }
CRON_KEY={ SECRET_CRON_KEY }

SUPABASE_URL={ SUPABASE_PROJECT_URL }
SUPABASE_KEY={ SUPABASE_SERVICE_ROLE_KEY }
SUPABASE_DB_URL={ SUPABASE_POSTGRES_CONNECTION_URL }

# ============================================================
# Database fallback / split credentials (optional)
# Use these only if SUPABASE_DB_URL does not include full auth.
# ============================================================
SUPABASE_DB_PASSWORD={ SUPABASE_DB_PASSWORD }
SUPABASE_DB_USER={ POSTGRES_USER_OPTIONAL_DEFAULT_POSTGRES }
SUPABASE_DB_NAME={ POSTGRES_DB_OPTIONAL_DEFAULT_POSTGRES }
SUPABASE_DB_HOST={ POSTGRES_HOST_OPTIONAL }
SUPABASE_DB_PORT={ POSTGRES_PORT_OPTIONAL_DEFAULT_5432 }

# Generic platform aliases (optional)
DATABASE_URL={ DATABASE_URL_OPTIONAL_ALIAS }
DATABASE_PASSWORD={ DATABASE_PASSWORD_OPTIONAL_ALIAS }
POSTGRES_URL={ POSTGRES_URL_OPTIONAL_ALIAS }
POSTGRES_PASSWORD={ POSTGRES_PASSWORD_OPTIONAL_ALIAS }
POSTGRES_USER={ POSTGRES_USER_OPTIONAL_ALIAS }
POSTGRES_DB={ POSTGRES_DB_OPTIONAL_ALIAS }
POSTGRES_HOST={ POSTGRES_HOST_OPTIONAL_ALIAS }
POSTGRES_PORT={ POSTGRES_PORT_OPTIONAL_ALIAS }

# ============================================================
# Telegram network tuning (optional)
# ============================================================
TELEGRAM_API_BASE={ HTTPS_API_TELEGRAM_ORG }
TELEGRAM_TIMEOUT_MS={ 16000 }
TELEGRAM_MAX_RETRIES={ 3 }
TELEGRAM_RETRY_BASE_MS={ 600 }
TELEGRAM_RETRY_MAX_MS={ 5000 }

# ============================================================
# Business defaults (optional)
# ============================================================
ACCOUNT_PRICE={ DEFAULT_ACCOUNT_PRICE_NUMBER }

# Runtime mode (optional)
NODE_ENV={ development_or_production }
